---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title }} — Notes</title>
  <link href="{{ site.url }}/feed.xml" rel="self"/>
  <link href="{{ site.url }}/"/>
  <id>{{ site.url }}/</id>
  <updated>{{ (collections.notes | reverse | first).date.toISOString() }}</updated>
  <author>
    <name>{{ site.title }}</name>
  </author>
{%- for note in collections.notes | reverse %}
  <entry>
    <title>{{ note.data.title }}</title>
    <link href="{{ site.url }}{{ note.url }}"/>
    <id>{{ site.url }}{{ note.url }}</id>
    <updated>{{ note.date.toISOString() }}</updated>
    <summary>{{ note.data.description }}</summary>
  </entry>
{%- endfor %}
</feed>
