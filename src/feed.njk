---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title }} — Notes</title>
  <link href="{{ site.url }}/feed.xml" rel="self"/>
  <link href="{{ site.url }}/"/>
  <id>{{ site.url }}/</id>
  <updated>{{ backendNotes[0].date_iso }}</updated>
  <author>
    <name>{{ site.title }}</name>
  </author>
{%- for note in backendNotes %}
  <entry>
    <title>{{ note.title }}</title>
    <link href="{{ site.url }}{{ note.url }}"/>
    <id>{{ site.url }}{{ note.url }}</id>
    <updated>{{ note.date_iso }}</updated>
    <summary>{{ note.description }}</summary>
  </entry>
{%- endfor %}
</feed>
